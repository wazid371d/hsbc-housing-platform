# Shared environment variable reference for local (non-Docker) runs.
# docker-compose sets these automatically via service-name hostnames.

# Python BFF (App 1 backend) -> ML API
BFF_ML_API_URL=http://localhost:8000

# Java backend (App 2) -> ML API
ML_API_URL=http://localhost:8000

# Next.js portal -> backends (server-side only)
BFF_URL=http://localhost:8001
MARKET_API_URL=http://localhost:8080

# --- ML API hardening (all optional) ---
# CORS allowlist for the ML API (JSON array). Defaults to localhost + the prod portal.
# ML_API_ALLOWED_ORIGINS=["http://localhost:3000"]
# Per-client rate limit for /predict and /model-info (requests/min; 0 disables).
# ML_API_RATE_LIMIT_PER_MINUTE=240
# Shared secret. To ENABLE API-key auth, set the SAME value on all three services:
#   ml-api service:          ML_API_KEY=<secret>   (require the key)
#   market-analysis service: ML_API_KEY=<secret>   (send the key)
#   bff-property service:    BFF_ML_API_KEY=<secret> (send the key)
# Leave all unset (default) to keep the ML API open.
# ML_API_KEY=
# BFF_ML_API_KEY=
# Fail-closed switch (ml-api only). When true, /predict and /model-info return 503 until
# ML_API_KEY is set — the API is unusable without the secret. Default false (open).
# ML_API_REQUIRE_KEY=false
